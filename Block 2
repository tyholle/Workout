.mr{display:grid;grid-template-columns:95px 1fr 1fr 1fr 1fr;gap:3px;align-items:center;margin-bottom:3px}
.lr{display:grid;grid-template-columns:1fr 48px 48px 48px 48px 48px 48px 48px 48px 48px;gap:3px;align-items:center;margin-bottom:3px}
