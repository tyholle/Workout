<script>
function sp(id,btn){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.nb').forEach(b=>b.classList.remove('active'));document.getElementById(id).classList.add('active');btn.classList.add('active');window.scrollTo(0,0)}
function sw(id,btn){document.querySelectorAll('.wc').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.wt').forEach(b=>b.classList.remove('active'));document.getElementById(id).classList.add('active');btn.classList.add('active')}
function tg(h){h.nextElementSibling.classList.toggle('open');h.classList.toggle('open')}
function saveAll(){const d={};document.querySelectorAll('input,textarea').forEach((el,i)=>{if(el.value)d['f'+i]=el.value});try{localStorage.setItem('b2d',JSON.stringify(d))}catch(e){}const n=document.getElementById('sok');n.style.display='block';setTimeout(()=>n.style.display='none',2000)}
function loadAll(){try{const r=localStorage.getItem('b2d');if(r){const d=JSON.parse(r);document.querySelectorAll('input,textarea').forEach((el,i)=>{if(d['f'+i])el.value=d['f'+i]})}}catch(e){}}
loadAll();document.addEventListener('input',()=>{clearTimeout(window._t);window._t=setTimeout(saveAll,1500)});
</script>
